---
import Layout from '../layouts/Layout.astro';
import DogList from '../components/DogList.astro';

const API_SERVER_URL = process.env.API_SERVER_URL || 'http://localhost:5100';
const PAGE_SIZE = 6;

let dogs = [];
let breeds = [];
let page = 1;
let totalPages = 1;
let error: string | null = null;

// 从 URL 获取页码
const currentPage = Math.max(1, Number(Astro.url.searchParams.get('page')) || 1);

try {
  // 获取品种列表
  const breedsResponse = await fetch(`${API_SERVER_URL}/api/breeds`);
  if (breedsResponse.ok) {
    const breedsData = await breedsResponse.json();
    breeds = breedsData.breeds;
  }

  // 获取狗狗（先不带过滤，前端处理）
  const dogsParams = new URLSearchParams({
    page: String(currentPage),
    per_page: String(PAGE_SIZE),
  });
  
  const dogsResponse = await fetch(`${API_SERVER_URL}/api/dogs?${dogsParams}`);
  if (dogsResponse.ok) {
    const dogsData = await dogsResponse.json();
    dogs = dogsData.dogs;
    page = dogsData.page;
    totalPages = dogsData.total_pages;
  } else {
    error = `Failed to fetch dogs: ${dogsResponse.status} ${dogsResponse.statusText}`;
  }
} catch (err) {
  error = `Error: ${err instanceof Error ? err.message : String(err)}`;
}
---

<Layout title="Tailspin Shelter - Find Your Forever Friend">
  <div class="py-8">
    <div class="max-w-3xl mb-10">
      <h1 class="text-4xl font-bold mb-4 text-slate-100">Welcome to Tailspin Shelter</h1>
      <p class="text-xl text-slate-300">Find your perfect companion from our wonderful selection of dogs looking for their forever homes.</p>
    </div>

    {/* Filters Section */}
    <div class="mb-8 p-6 bg-slate-800/60 backdrop-blur-sm rounded-xl border border-slate-700" data-testid="filters">
      <h3 class="text-lg font-semibold text-slate-100 mb-4">Filters</h3>
      <div class="flex flex-col sm:flex-row gap-4">
        {/* Breed Dropdown */}
        <div class="flex-1">
          <label for="breed-filter" class="block text-sm font-medium text-slate-300 mb-2">
            Breed
          </label>
          <select
            id="breed-filter"
            class="w-full px-4 py-2 bg-slate-700 border border-slate-600 rounded-lg text-slate-100 focus:border-blue-500 focus:outline-none transition-colors"
            data-testid="breed-filter"
          >
            <option value="">All Breeds</option>
            {breeds.map((breed) => (
              <option value={breed.name}>
                {breed.name}
              </option>
            ))}
          </select>
        </div>

        {/* Available Only Checkbox */}
        <div class="flex items-end">
          <label class="flex items-center gap-2 cursor-pointer text-slate-300 hover:text-slate-100 transition-colors" data-testid="available-filter-label">
            <input
              type="checkbox"
              id="available-filter"
              class="w-4 h-4 bg-slate-700 border border-slate-600 rounded focus:ring-2 focus:ring-blue-500 cursor-pointer"
              data-testid="available-filter"
            />
            <span class="text-sm font-medium">Available Only</span>
          </label>
        </div>
      </div>
    </div>

    {error ? (
      <div class="text-center py-12 bg-slate-800/50 backdrop-blur-sm rounded-xl border border-slate-700" data-testid="error-message">
        <p class="text-red-400">{error}</p>
      </div>
    ) : (
      <>
        <DogList dogs={dogs} />

        {totalPages > 1 && (
          <nav class="flex justify-center items-center gap-2 mt-10" data-testid="pagination">
            {page > 1 ? (
              <a
                href={`/?page=${page - 1}`}
                class="px-4 py-2 rounded-lg bg-slate-800 border border-slate-700 text-slate-300 hover:border-blue-500/50 hover:text-blue-400 transition-colors"
                data-testid="pagination-prev"
              >
                ← Previous
              </a>
            ) : (
              <span class="px-4 py-2 rounded-lg bg-slate-800/50 border border-slate-700/50 text-slate-600 cursor-not-allowed">
                ← Previous
              </span>
            )}

            <span class="px-4 py-2 text-slate-300" data-testid="pagination-info">
              Page {page} of {totalPages}
            </span>

            {page < totalPages ? (
              <a
                href={`/?page=${page + 1}`}
                class="px-4 py-2 rounded-lg bg-slate-800 border border-slate-700 text-slate-300 hover:border-blue-500/50 hover:text-blue-400 transition-colors"
                data-testid="pagination-next"
              >
                Next →
              </a>
            ) : (
              <span class="px-4 py-2 rounded-lg bg-slate-800/50 border border-slate-700/50 text-slate-600 cursor-not-allowed">
                Next →
              </span>
            )}
          </nav>
        )}
      </>
    )}
  </div>
</Layout>

<script define:vars={{ API_SERVER_URL: API_SERVER_URL || 'http://localhost:5100' }}>
  const PAGE_SIZE = 6;
  
  const breedFilter = document.getElementById('breed-filter') as HTMLSelectElement;
  const availableFilter = document.getElementById('available-filter') as HTMLInputElement;
  const dogListContainer = document.querySelector('[data-testid="dog-list"]')?.parentElement;
  const emptyStateContainer = document.querySelector('[data-testid="empty-state"]')?.parentElement;
  const paginationNav = document.querySelector('[data-testid="pagination"]') as HTMLElement;

  let currentPage = 1;
  let currentFilters = { breed: '', available: false };

  function loadFiltersFromLocalStorage() {
    const filters = JSON.parse(localStorage.getItem('dogFilters') || '{}');
    breedFilter.value = filters.breed || '';
    availableFilter.checked = filters.available || false;
    currentFilters = filters;
  }

  function saveFiltersToLocalStorage() {
    const filters = {
      breed: breedFilter.value,
      available: availableFilter.checked,
    };
    currentFilters = filters;
    localStorage.setItem('dogFilters', JSON.stringify(filters));
  }

  async function loadDogs(page: number = 1) {
    try {
      const params = new URLSearchParams({
        page: String(page),
        per_page: String(PAGE_SIZE),
      });

      if (currentFilters.breed) {
        params.append('breed', currentFilters.breed);
      }
      if (currentFilters.available) {
        params.append('available', 'true');
      }

      const response = await fetch(`${API_SERVER_URL}/api/dogs?${params}`);
      if (!response.ok) throw new Error('Failed to fetch dogs');

      const data = await response.json();
      currentPage = page;
      renderDogs(data);
    } catch (err) {
      console.error('Error loading dogs:', err);
    }
  }

  function renderDogs(data: any) {
    const totalPages = data.total_pages;

    // 更新狗狗列表
    if (data.dogs.length === 0) {
      if (dogListContainer) dogListContainer.style.display = 'none';
      if (emptyStateContainer) emptyStateContainer.style.display = 'block';
    } else {
      if (dogListContainer) dogListContainer.style.display = 'block';
      if (emptyStateContainer) emptyStateContainer.style.display = 'none';

      const html = data.dogs.map((dog: any) => `
        <a
          href="/dog/${dog.id}"
          class="group block bg-slate-800/60 backdrop-blur-sm rounded-xl overflow-hidden shadow-lg border border-slate-700/50 hover:border-blue-500/50 hover:shadow-blue-500/10 hover:shadow-xl transition-all duration-300 hover:translate-y-[-6px]"
          data-testid="dog-card"
        >
          <div class="p-6 relative">
            <div class="absolute inset-0 bg-gradient-to-r from-blue-600/10 to-purple-600/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <div class="relative z-10">
              <h3 class="text-xl font-semibold text-slate-100 mb-2 group-hover:text-blue-400 transition-colors" data-testid="dog-name">${dog.name}</h3>
              <p class="text-slate-400 mb-4" data-testid="dog-breed">${dog.breed}</p>
              <div class="mt-4 text-sm text-blue-400 font-medium flex items-center">
                <span>View details</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1 transform transition-transform duration-300 group-hover:translate-x-2" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
              </div>
            </div>
          </div>
        </a>
      `).join('');

      const dogGrid = dogListContainer?.querySelector('[data-testid="dog-list"]');
      if (dogGrid) dogGrid.innerHTML = html;
    }

    // 更新分页
    if (paginationNav) {
      if (totalPages > 1) {
        paginationNav.style.display = 'flex';
        const prevBtn = paginationNav.querySelector('[data-testid="pagination-prev"]') as HTMLElement;
        const nextBtn = paginationNav.querySelector('[data-testid="pagination-next"]') as HTMLElement;
        const pageInfo = paginationNav.querySelector('[data-testid="pagination-info"]');

        if (pageInfo) pageInfo.textContent = `Page ${currentPage} of ${totalPages}`;

        if (prevBtn) {
          if (currentPage > 1) {
            prevBtn.innerHTML = '← Previous';
            prevBtn.setAttribute('onclick', `window.dogsPageManager && window.dogsPageManager.goToPage(${currentPage - 1})`);
            prevBtn.style.pointerEvents = 'auto';
          } else {
            prevBtn.style.pointerEvents = 'none';
          }
        }

        if (nextBtn) {
          if (currentPage < totalPages) {
            nextBtn.innerHTML = 'Next →';
            nextBtn.setAttribute('onclick', `window.dogsPageManager && window.dogsPageManager.goToPage(${currentPage + 1})`);
            nextBtn.style.pointerEvents = 'auto';
          } else {
            nextBtn.style.pointerEvents = 'none';
          }
        }
      } else {
        paginationNav.style.display = 'none';
      }
    }
  }

  function updateFilters() {
    saveFiltersToLocalStorage();
    loadDogs(1);
  }

  // 全局方法供分页按钮调用
  window.dogsPageManager = { goToPage: loadDogs };

  // 从 bfcache 恢复时，重新加载
  window.addEventListener('pageshow', (event) => {
    if (event.persisted) {
      loadFiltersFromLocalStorage();
      loadDogs(1);
    }
  });

  // 初始化
  loadFiltersFromLocalStorage();
  loadDogs(1);

  breedFilter?.addEventListener('change', updateFilters);
  availableFilter?.addEventListener('change', updateFilters);
</script>
